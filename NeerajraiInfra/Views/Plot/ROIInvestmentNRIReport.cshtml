

@{
    ViewBag.Title = "ROIInvestmentNRIReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<section class="section">
    <ul class="breadcrumb breadcrumb-style ">
        <li class="breadcrumb-item">
            <a href="#">
                <i data-feather="home"></i>
            </a>
        </li>
        <li class="breadcrumb-item">Reports</li>
        <li class="breadcrumb-item">ROI Report </li>
    </ul>
</section>



<div class="card">
    <div class="card-body">

        <div class="table-responsive">
            <table class="table table-bordered table-striped" id="roiTable">
                <thead style="background-color:#f5f5f5;">
                    <tr>
                        <th>#</th>
                        <th>Login ID</th>
                        <th>Full Name</th>
                        @*<th>Investment ID</th>*@
                        <th>Amount</th>
                        <th>Installment</th>
                        <th>ROI</th>
                        <th>ROI Date</th>
                        <th>Status</th>
                        <th>Booking Date</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null)
                    {
                        int count = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td>@item.LoginId</td>
                                <td>@item.FullName</td>
                                @*<td>@item.Fk_InvestId</td>*@
                                <td>₹@item.InvestmentAmount</td>
                                <td>@item.ROIInstallment</td>
                                <td>₹@item.ROI</td>
                                <td>@item.ROIDate</td>
                                <td>
                                    @if (item.Status == 0)
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                </td>
                                <td>
                                    @if (item.BookingDate != null)
                                    {
                                        @item.BookingDate
                                    }
                                </td>
                            </tr>

                            count++;
                        }
                    }
                </tbody>

            </table>
        </div>

    </div>
</div>
<script src="~/files/bower_components/jquery/js/jquery.min.js"></script>
<script src="//code.jquery.com/ui/1.11.4/jquery-ui.js"></script>
<link rel="stylesheet" type="text/css" href="https://code.jquery.com/ui/1.12.0/themes/smoothness/jquery-ui.css">
<script>
    render: function (data) {
        return moment(data).format('DD/MM/YYYY');
    }
</script>